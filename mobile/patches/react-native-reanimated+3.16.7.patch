+void NativeProxy::progressLayoutAnimation(
+    jsi::Runtime &rt,
+    int tag,
+    const jsi::Object &newProps,
+    bool isSharedTransition) {
+  auto newPropsJNI = JNIHelper::ConvertToPropsMap(rt, newProps);
